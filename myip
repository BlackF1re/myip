#!/bin/sh
# myip: portable public IP helper with self-install and startup auto-update.

set -eu

APP_NAME="myip"
DISPLAY_NAME="myip by BlackF1re"
VERSION="1.1.0"
GITHUB_REPO="${MYIP_GITHUB_REPO:-BlackF1re/myip}"
GITHUB_BRANCH="${MYIP_GITHUB_BRANCH:-master}"
AUTO_UPDATE="${MYIP_AUTO_UPDATE:-1}"
AUTO_UPDATE_INTERVAL="${MYIP_AUTO_UPDATE_INTERVAL:-0}"
AUTO_UPDATE_URL="${MYIP_AUTO_UPDATE_URL:-https://raw.githubusercontent.com/$GITHUB_REPO/$GITHUB_BRANCH/$APP_NAME}"
STAMP="${TMPDIR:-/tmp}/$APP_NAME.self-update.stamp"
CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME:-.}/.config}/myip"
CONFIG_FILE="$CONFIG_DIR/config"
MARKER_BEGIN="# >>> myip PATH >>>"
MARKER_END="# <<< myip PATH <<<"
GREEN="$(printf '\033[32m')"
RESET="$(printf '\033[0m')"
QUIET_INSTALL="0"

mkdir -p "$CONFIG_DIR" 2>/dev/null || true
[ -r "$CONFIG_FILE" ] && . "$CONFIG_FILE"

say() { printf '%s\n' "$*"; }
err() { printf 'myip: %s\n' "$*" >&2; }
green() { printf '%s%s%s' "$GREEN" "$1" "$RESET"; }

save_config() {
    tmp="$CONFIG_FILE.tmp.$$"
    umask 077
    {
        printf "DOWNLOADER='%s'\n" "${DOWNLOADER:-}"
        printf "DOWNLOADER_LABEL='%s'\n" "${DOWNLOADER_LABEL:-}"
    } > "$tmp" && mv "$tmp" "$CONFIG_FILE"
}

resolve_downloader() {
    if [ -n "${DOWNLOADER:-}" ] && [ -x "$DOWNLOADER" ]; then
        case "${DOWNLOADER_LABEL:-}" in curl|wget) return 0;; esac
    fi
    if command -v curl >/dev/null 2>&1; then
        DOWNLOADER="$(command -v curl)"; DOWNLOADER_LABEL="curl"; save_config; return 0
    fi
    if command -v wget >/dev/null 2>&1; then
        DOWNLOADER="$(command -v wget)"; DOWNLOADER_LABEL="wget"; save_config; return 0
    fi
    err "neither curl nor wget was found in PATH"
    exit 1
}

fetch_url() {
    url="$1"
    resolve_downloader
    if [ "$DOWNLOADER_LABEL" = curl ]; then
        "$DOWNLOADER" --connect-timeout 4 --max-time 12 -fsSL "$url"
    else
        "$DOWNLOADER" --timeout=12 -qO- "$url"
    fi
}

download_file() {
    url="$1"; out="$2"
    resolve_downloader
    if [ "$DOWNLOADER_LABEL" = curl ]; then
        "$DOWNLOADER" --connect-timeout 4 --max-time 20 -fsSL -o "$out" "$url"
    else
        "$DOWNLOADER" --timeout=20 -qO "$out" "$url"
    fi
}

script_path() {
    case "$0" in
        /*) printf '%s\n' "$0";;
        */*) printf '%s/%s\n' "$(cd "$(dirname "$0")" 2>/dev/null && pwd)" "$(basename "$0")";;
        *) command -v "$0" 2>/dev/null || printf '%s\n' "$0";;
    esac
}

extract_version() {
    sed -n 's/^VERSION="\([^"]*\)"$/\1/p' "$1" 2>/dev/null | head -n 1
}

ver_nums() {
    old_ifs=$IFS; IFS=.; set -- $1; IFS=$old_ifs
    a=$(printf '%s' "${1:-0}" | sed 's/[^0-9].*$//')
    b=$(printf '%s' "${2:-0}" | sed 's/[^0-9].*$//')
    c=$(printf '%s' "${3:-0}" | sed 's/[^0-9].*$//')
    printf '%s %s %s\n' "${a:-0}" "${b:-0}" "${c:-0}"
}

ver_cmp() {
    set -- $(ver_nums "$1"); la=$1; lb=$2; lc=$3
    set -- $(ver_nums "$2"); ra=$1; rb=$2; rc=$3
    [ "$la" -gt "$ra" ] && { echo 1; return; }
    [ "$la" -lt "$ra" ] && { echo -1; return; }
    [ "$lb" -gt "$rb" ] && { echo 1; return; }
    [ "$lb" -lt "$rb" ] && { echo -1; return; }
    [ "$lc" -gt "$rc" ] && { echo 1; return; }
    [ "$lc" -lt "$rc" ] && { echo -1; return; }
    echo 0
}

update_due() {
    case "$AUTO_UPDATE_INTERVAL" in ''|*[!0-9]*) return 0;; esac
    [ "$AUTO_UPDATE_INTERVAL" -eq 0 ] && return 0
    [ -f "$STAMP" ] || return 0
    last=$(cat "$STAMP" 2>/dev/null || echo 0)
    case "$last" in ''|*[!0-9]*) return 0;; esac
    now=$(date +%s 2>/dev/null || echo 0)
    [ $((now - last)) -ge "$AUTO_UPDATE_INTERVAL" ]
}

mark_update_check() { date +%s > "$STAMP" 2>/dev/null || true; }

install_file() {
    src="$1"; dst="$2"; tmp="$dst.tmp.$$"
    cp "$src" "$tmp" && chmod 755 "$tmp" && mv "$tmp" "$dst"
}

self_update() {
    [ "$AUTO_UPDATE" = 1 ] || return 0
    [ "${MYIP_SKIP_SELF_UPDATE:-0}" = 1 ] && return 0
    update_due || return 0
    cur=$(script_path)
    [ -f "$cur" ] || return 0
    tmp="${TMPDIR:-/tmp}/$APP_NAME.update.$$"
    download_file "$AUTO_UPDATE_URL" "$tmp" >/dev/null 2>&1 || { mark_update_check; rm -f "$tmp"; return 0; }
    mark_update_check
    [ -s "$tmp" ] || { rm -f "$tmp"; return 0; }
    sh -n "$tmp" >/dev/null 2>&1 || { err "downloaded update failed syntax check"; rm -f "$tmp"; return 0; }
    rv=$(extract_version "$tmp" || true)
    [ -n "$rv" ] || { rm -f "$tmp"; return 0; }
    [ "$(ver_cmp "$rv" "$VERSION")" = -1 ] && { rm -f "$tmp"; return 0; }
    cmp -s "$tmp" "$cur" && { rm -f "$tmp"; return 0; }
    if install_file "$tmp" "$cur"; then
        rm -f "$tmp"
        err "updated from GitHub: $AUTO_UPDATE_URL"
        MYIP_SKIP_SELF_UPDATE=1 exec "$cur" "$@"
    fi
    rm -f "$tmp"
    err "failed to install downloaded update"
}

choose_install_dir() {
    if [ -n "${PREFIX:-}" ] && [ -w "$PREFIX/bin" ]; then echo "$PREFIX/bin"; return; fi
    if [ -n "${HOME:-}" ]; then mkdir -p "$HOME/.local/bin" 2>/dev/null && { echo "$HOME/.local/bin"; return; }; fi
    if [ -w /usr/local/bin ]; then echo /usr/local/bin; return; fi
    pwd
}

path_has() { case ":$PATH:" in *":$1:"*) return 0;; *) return 1;; esac; }

add_path_hook() {
    dir="$1"
    [ -n "${HOME:-}" ] || return 0
    rc="$HOME/.profile"
    [ -n "${SHELL:-}" ] && [ "$(basename "$SHELL")" = bash ] && rc="$HOME/.bashrc"
    [ -f "$rc" ] || : > "$rc" 2>/dev/null || return 0
    grep -F "$MARKER_BEGIN" "$rc" >/dev/null 2>&1 && return 0
    {
        printf '\n%s\n' "$MARKER_BEGIN"
        printf 'case ":$PATH:" in\n  *:%s:*) ;;\n  *) export PATH="%s:$PATH" ;;\nesac\n' "$dir" "$dir"
        printf '%s\n' "$MARKER_END"
    } >> "$rc" || true
}

self_install() {
    src=$(script_path)
    [ -f "$src" ] || return 0
    dir=$(choose_install_dir)
    dst="$dir/$APP_NAME"
    [ "$src" = "$dst" ] || {
        old=""; [ -f "$dst" ] && old=$(extract_version "$dst" || true)
        if [ -n "$old" ] && [ "$(ver_cmp "$VERSION" "$old")" = -1 ]; then
            err "installed copy at $dst is newer ($old); refusing to overwrite it with $VERSION"
        elif ! cmp -s "$src" "$dst" 2>/dev/null; then
            install_file "$src" "$dst"
            msg="$APP_NAME successfully updated to $(green "$VERSION")"
            [ -n "$old" ] && msg="$APP_NAME successfully updated from $(green "$old") to $(green "$VERSION")"
            if [ "$QUIET_INSTALL" = 1 ]; then err "$msg"; else say "$msg"; say "Путь: $(green "$dst")"; fi
        fi
    }
    path_has "$dir" || { add_path_hook "$dir"; PATH="$dir:$PATH"; export PATH; }
}

remove_path_hooks() {
    [ -n "${HOME:-}" ] || return 0
    for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.profile"; do
        [ -f "$rc" ] || continue
        tmp="$rc.myip.tmp.$$"
        awk -v b="$MARKER_BEGIN" -v e="$MARKER_END" '$0==b{skip=1;next}$0==e{skip=0;next}skip!=1{print}' "$rc" > "$tmp" && mv "$tmp" "$rc"
    done
}

json_get() { printf '%s' "$1" | sed -n "s/.*\"$2\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" | head -n 1; }

load_backend() {
    IPAPI_JSON=$(fetch_url 'https://ipapi.co/json/' 2>/dev/null || true)
    if [ -n "$IPAPI_JSON" ] && json_get "$IPAPI_JSON" ip >/dev/null; then BACKEND=ipapi; return 0; fi
    GEO_JSON=$(fetch_url 'https://api.2ip.me/geo.json?ip=' 2>/dev/null || true)
    PROVIDER_JSON=$(fetch_url 'https://api.2ip.me/provider.json?ip=' 2>/dev/null || true)
    [ -n "$GEO_JSON" ] || { err "failed to query both ipapi.co and 2ip.me"; exit 1; }
    BACKEND=2ip
    err "ipapi.co is unavailable; using 2ip.me fallback"
}

field() {
    key="$1"
    if [ "$BACKEND" = ipapi ]; then json_get "$IPAPI_JSON" "$key"; return; fi
    case "$key" in
        ip) json_get "$GEO_JSON" ip;;
        country_name) v=$(json_get "$GEO_JSON" country_rus); [ -n "$v" ] || v=$(json_get "$GEO_JSON" country); printf '%s' "$v";;
        region) v=$(json_get "$GEO_JSON" region_rus); [ -n "$v" ] || v=$(json_get "$GEO_JSON" region); printf '%s' "$v";;
        city) v=$(json_get "$GEO_JSON" city_rus); [ -n "$v" ] || v=$(json_get "$GEO_JSON" city); printf '%s' "$v";;
        org) v=$(json_get "$PROVIDER_JSON" name_rus); [ -n "$v" ] || v=$(json_get "$PROVIDER_JSON" name_ripe); printf '%s' "$v";;
        asn) v=$(json_get "$PROVIDER_JSON" as); [ -n "$v" ] && printf 'AS%s' "$v";;
        timezone) printf 'N/A (2ip.me fallback)';;
    esac
}

print_report() {
    load_backend
    printf 'IP: %s\n' "$(green "$(field ip)")"
    printf 'Country: %s\n' "$(green "$(field country_name)")"
    printf 'Region: %s\n' "$(field region)"
    printf 'City: %s\n' "$(field city)"
    printf 'Org: %s\n' "$(field org)"
    printf 'ASN: %s\n' "$(field asn)"
    printf 'Timezone: %s\n' "$(field timezone)"
}

print_ip() { load_backend; field ip; printf '\n'; }
print_json() { load_backend; [ "$BACKEND" = ipapi ] && { printf '%s\n' "$IPAPI_JSON"; return; }; printf '{"backend":"2ip.me","ip":"%s","country_name":"%s","region":"%s","city":"%s","org":"%s","asn":"%s","timezone":"%s"}\n' "$(field ip)" "$(field country_name)" "$(field region)" "$(field city)" "$(field org)" "$(field asn)" "$(field timezone)"; }

manual_update() {
    cur=$(command -v "$APP_NAME" 2>/dev/null || script_path)
    tmp="${TMPDIR:-/tmp}/$APP_NAME.manual-update.$$"
    download_file "$AUTO_UPDATE_URL" "$tmp" >/dev/null 2>&1 || { rm -f "$tmp"; err "failed to fetch update from GitHub"; exit 1; }
    [ -s "$tmp" ] || { rm -f "$tmp"; err "downloaded update is empty"; exit 1; }
    sh -n "$tmp" >/dev/null 2>&1 || { rm -f "$tmp"; err "downloaded update failed syntax check"; exit 1; }
    rv=$(extract_version "$tmp" || true)
    [ -n "$rv" ] || { rm -f "$tmp"; err "downloaded update has no VERSION"; exit 1; }
    [ "$(ver_cmp "$rv" "$VERSION")" = -1 ] && { rm -f "$tmp"; err "remote version $rv is older than local version $VERSION"; exit 1; }
    cmp -s "$tmp" "$cur" && { rm -f "$tmp"; say "$(green "$APP_NAME") is already up to date at $(green "$VERSION")"; return 0; }
    install_file "$tmp" "$cur" && rm -f "$tmp"
    say "$(green "$APP_NAME") successfully updated from $(green "$VERSION") to $(green "$rv")"
    say "Путь: $(green "$cur")"
}

usage() { cat <<USAGE
Usage: myip [--json] [--ip] [--version] [--remove] [--update]

  --json     print raw JSON from ipapi.co, or normalized fallback JSON from 2ip.me
  --ip       print only the public IP
  --version  print version, install path, and update settings
  --remove   remove installed myip, config, and PATH hook
  --update   update installed myip from GitHub now

Environment:
  MYIP_AUTO_UPDATE=0              disable auto-update on startup
  MYIP_AUTO_UPDATE_INTERVAL=3600  check at most once per hour
  MYIP_GITHUB_REPO=owner/repo     override update repository
  MYIP_GITHUB_BRANCH=branch       override update branch
  MYIP_AUTO_UPDATE_URL=url        override full raw script URL
USAGE
}

case "${1:-}" in
    --remove)
        rm -f "$(command -v "$APP_NAME" 2>/dev/null || true)" "$CONFIG_FILE" 2>/dev/null || true
        remove_path_hooks
        say "removed myip installation, config, and PATH hooks where present"
        ;;
    --update)
        manual_update
        ;;
    -h|--help)
        usage
        ;;
    --version)
        self_update "$@"
        say "$(green "$DISPLAY_NAME") версии $(green "$VERSION") установлен в $(green "$(command -v "$APP_NAME" 2>/dev/null || script_path)")"
        say "Auto-update: $(green "$AUTO_UPDATE")"
        say "Update URL: $(green "$AUTO_UPDATE_URL")"
        ;;
    --ip)
        self_update "$@"
        QUIET_INSTALL=1; self_install
        print_ip
        ;;
    --json)
        self_update "$@"
        QUIET_INSTALL=1; self_install
        print_json
        ;;
    "")
        self_update "$@"
        self_install
        print_report
        ;;
    *)
        self_update "$@"
        self_install
        err "unknown option: $1"
        usage >&2
        exit 1
        ;;
esac
