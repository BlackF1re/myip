#!/bin/sh
#
# myip: portable IP info helper for Linux-like systems.
# Install: copy this file anywhere and run it once, or place it in ~/.local/bin/myip and chmod +x ~/.local/bin/myip
# First run: the script will try to copy itself into a user bin directory and add that directory to PATH if needed.
# Usage: myip | myip --ip | myip --json

set -eu

APP_NAME="myip"
DISPLAY_NAME="myip by BlackF1re"
VERSION="1.0.0"
MARKER_BEGIN="# >>> myip PATH >>>"
MARKER_END="# <<< myip PATH <<<"
GREEN="$(printf '\033[32m')"
RESET="$(printf '\033[0m')"

HOME_DIR="${HOME:-}"
PREFIX_DIR="${PREFIX:-}"
GITHUB_REPO="${MYIP_GITHUB_REPO:-}"
GITHUB_BRANCH="${MYIP_GITHUB_BRANCH:-main}"

if [ -n "${XDG_CONFIG_HOME:-}" ]; then
    CONFIG_HOME="$XDG_CONFIG_HOME"
elif [ -n "$HOME_DIR" ]; then
    CONFIG_HOME="$HOME_DIR/.config"
else
    CONFIG_HOME="."
fi

CONFIG_DIR="$CONFIG_HOME/myip"
CONFIG_FILE="$CONFIG_DIR/config"

mkdir -p "$CONFIG_DIR"

DOWNLOADER=""
DOWNLOADER_LABEL=""
INSTALL_TARGET=""
INSTALL_NAME=""
INSTALL_CHANGED="0"
INSTALL_ACTION=""
PREVIOUS_VERSION=""
PATH_UPDATED="0"
PATH_UPDATE_FAILED="0"
INSTALL_WARNING=""
RAN_FROM_STDIN="0"
ACTIVE_BACKEND=""
BACKEND_NOTICE_SHOWN="0"
IPAPI_JSON=""
TWOIP_GEO_JSON=""
TWOIP_PROVIDER_JSON=""
REMOTE_SCRIPT=""
REMOTE_VERSION=""
REMOTE_COMMIT_MESSAGE=""
UPDATE_CHECK_DONE="0"

green() {
    printf "%s%s%s" "$GREEN" "$1" "$RESET"
}

info() {
    printf "%s\n" "$1"
}

warn() {
    printf "myip: %s\n" "$1" >&2
}

extract_version() {
    file_path="$1"
    if [ ! -f "$file_path" ]; then
        return 1
    fi

    sed -n 's/^VERSION="\([^"]*\)"$/\1/p' "$file_path" | head -n 1
}

version_to_ints() {
    version_string="$1"
    old_ifs="${IFS}"
    IFS=.
    set -- $version_string
    IFS="$old_ifs"

    printf "%s %s %s\n" "${1:-0}" "${2:-0}" "${3:-0}"
}

version_compare() {
    left="$1"
    right="$2"

    set -- $(version_to_ints "$left")
    left_a="${1:-0}"
    left_b="${2:-0}"
    left_c="${3:-0}"

    set -- $(version_to_ints "$right")
    right_a="${1:-0}"
    right_b="${2:-0}"
    right_c="${3:-0}"

    if [ "$left_a" -gt "$right_a" ]; then
        echo 1
        return 0
    fi
    if [ "$left_a" -lt "$right_a" ]; then
        echo -1
        return 0
    fi
    if [ "$left_b" -gt "$right_b" ]; then
        echo 1
        return 0
    fi
    if [ "$left_b" -lt "$right_b" ]; then
        echo -1
        return 0
    fi
    if [ "$left_c" -gt "$right_c" ]; then
        echo 1
        return 0
    fi
    if [ "$left_c" -lt "$right_c" ]; then
        echo -1
        return 0
    fi

    echo 0
}

has_update_source() {
    [ -n "$GITHUB_REPO" ]
}

get_remote_script_url() {
    printf "https://raw.githubusercontent.com/%s/%s/myip\n" "$GITHUB_REPO" "$GITHUB_BRANCH"
}

get_remote_commit_api_url() {
    printf "https://api.github.com/repos/%s/commits?sha=%s&path=myip&per_page=1\n" "$GITHUB_REPO" "$GITHUB_BRANCH"
}

extract_commit_message() {
    json_payload="$1"
    compact_json="$(printf "%s" "$json_payload" | tr '\n' ' ')"
    message="$(printf "%s" "$compact_json" | sed -n 's/.*"message"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
    message="$(printf "%s" "$message" | sed 's/\\\\n/ /g; s/\\"/"/g; s/\\\\r//g')"
    printf "%s" "$message"
}

load_remote_version() {
    [ "$UPDATE_CHECK_DONE" = "0" ] || return 0
    UPDATE_CHECK_DONE="1"

    has_update_source || return 1

    remote_url="$(get_remote_script_url)"
    REMOTE_SCRIPT="$(fetch_url "$remote_url" 2>/dev/null)" || return 1
    REMOTE_VERSION="$(printf "%s" "$REMOTE_SCRIPT" | sed -n 's/^VERSION="\([^"]*\)"$/\1/p' | head -n 1)"
    commit_api_url="$(get_remote_commit_api_url)"
    remote_commit_json="$(fetch_url "$commit_api_url" 2>/dev/null || true)"
    if [ -n "$remote_commit_json" ]; then
        REMOTE_COMMIT_MESSAGE="$(extract_commit_message "$remote_commit_json")"
    fi

    [ -n "$REMOTE_VERSION" ]
}

maybe_show_update_notice() {
    load_remote_version || return 0

    comparison="$(version_compare "$REMOTE_VERSION" "$VERSION")"
    if [ "$comparison" = "1" ]; then
        info "Update available: $(green "$VERSION") -> $(green "$REMOTE_VERSION"). Run $(green "$APP_NAME --update")"
        if [ -n "$REMOTE_COMMIT_MESSAGE" ]; then
            info "Commit: $(green "$REMOTE_COMMIT_MESSAGE")"
        fi
    fi
}

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck disable=SC1090
        . "$CONFIG_FILE"
    fi
}

save_config() {
    tmp_file="$CONFIG_FILE.tmp.$$"
    umask 077
    {
        printf "DOWNLOADER='%s'\n" "$DOWNLOADER"
        printf "DOWNLOADER_LABEL='%s'\n" "$DOWNLOADER_LABEL"
    } > "$tmp_file"
    mv "$tmp_file" "$CONFIG_FILE"
}

resolve_downloader() {
    if [ -n "${DOWNLOADER:-}" ] && [ -x "$DOWNLOADER" ]; then
        return 0
    fi

    if command -v curl >/dev/null 2>&1; then
        DOWNLOADER="$(command -v curl)"
        DOWNLOADER_LABEL="curl"
    elif command -v wget >/dev/null 2>&1; then
        DOWNLOADER="$(command -v wget)"
        DOWNLOADER_LABEL="wget"
    else
        echo "myip: neither curl nor wget was found in PATH" >&2
        exit 1
    fi

    save_config
}

fetch_url() {
    url="$1"

    if [ "$DOWNLOADER_LABEL" = "curl" ]; then
        if "$DOWNLOADER" --connect-timeout 4 --max-time 8 -fsSL "$url"; then
            return 0
        fi
        if command -v wget >/dev/null 2>&1; then
            DOWNLOADER="$(command -v wget)"
            DOWNLOADER_LABEL="wget"
            save_config
            "$DOWNLOADER" --timeout=8 -qO- "$url"
            return 0
        fi
    else
        if "$DOWNLOADER" --timeout=8 -qO- "$url"; then
            return 0
        fi
        if command -v curl >/dev/null 2>&1; then
            DOWNLOADER="$(command -v curl)"
            DOWNLOADER_LABEL="curl"
            save_config
            "$DOWNLOADER" --connect-timeout 4 --max-time 8 -fsSL "$url"
            return 0
        fi
    fi

    return 1
}

trim_line() {
    printf "%s" "$1" | tr -d '\r'
}

json_get_string() {
    json_payload="$1"
    key="$2"
    printf "%s" "$json_payload" | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" | head -n 1
}

show_backend_notice() {
    if [ "$BACKEND_NOTICE_SHOWN" = "1" ]; then
        return 0
    fi

    if [ "$ACTIVE_BACKEND" = "2ip" ]; then
        warn "ipapi.co is unavailable; using 2ip.me fallback"
    fi

    BACKEND_NOTICE_SHOWN="1"
}

load_ipapi_backend() {
    IPAPI_JSON="$(fetch_url "https://ipapi.co/json/" 2>/dev/null)" || return 1
    ACTIVE_BACKEND="ipapi"
    return 0
}

load_2ip_backend() {
    TWOIP_GEO_JSON="$(fetch_url "https://api.2ip.me/geo.json?ip=" 2>/dev/null)" || return 1
    TWOIP_PROVIDER_JSON="$(fetch_url "https://api.2ip.me/provider.json?ip=" 2>/dev/null || true)"
    ACTIVE_BACKEND="2ip"
    show_backend_notice
    return 0
}

ensure_backend() {
    if [ -n "$ACTIVE_BACKEND" ]; then
        return 0
    fi

    if load_ipapi_backend; then
        return 0
    fi

    if load_2ip_backend; then
        return 0
    fi

    warn "failed to query both ipapi.co and 2ip.me"
    exit 1
}

get_ipapi_field() {
    field="$1"
    value="$(json_get_string "$IPAPI_JSON" "$field")"
    trim_line "$value"
}

get_2ip_field() {
    field="$1"
    case "$field" in
        ip)
            value="$(json_get_string "$TWOIP_GEO_JSON" "ip")"
            ;;
        country_name)
            value="$(json_get_string "$TWOIP_GEO_JSON" "country_rus")"
            if [ -z "$value" ]; then
                value="$(json_get_string "$TWOIP_GEO_JSON" "country")"
            fi
            ;;
        region)
            value="$(json_get_string "$TWOIP_GEO_JSON" "region_rus")"
            if [ -z "$value" ]; then
                value="$(json_get_string "$TWOIP_GEO_JSON" "region")"
            fi
            ;;
        city)
            value="$(json_get_string "$TWOIP_GEO_JSON" "city_rus")"
            if [ -z "$value" ]; then
                value="$(json_get_string "$TWOIP_GEO_JSON" "city")"
            fi
            ;;
        org)
            value="$(json_get_string "$TWOIP_PROVIDER_JSON" "name_rus")"
            if [ -z "$value" ]; then
                value="$(json_get_string "$TWOIP_PROVIDER_JSON" "name_ripe")"
            fi
            ;;
        asn)
            value="$(json_get_string "$TWOIP_PROVIDER_JSON" "as")"
            if [ -n "$value" ]; then
                value="AS$value"
            fi
            ;;
        timezone)
            value="N/A (2ip.me fallback)"
            ;;
        *)
            value=""
            ;;
    esac

    trim_line "$value"
}

get_field() {
    field="$1"
    case "$ACTIVE_BACKEND" in
        ipapi)
            get_ipapi_field "$field"
            ;;
        2ip)
            get_2ip_field "$field"
            ;;
        *)
            warn "unknown backend: $ACTIVE_BACKEND"
            exit 1
            ;;
    esac
}

current_shell_name() {
    shell_path="${SHELL:-}"
    if [ -n "$shell_path" ]; then
        basename "$shell_path"
        return 0
    fi
    echo "sh"
}

choose_install_dir() {
    if [ -n "$PREFIX_DIR" ] && [ -d "$PREFIX_DIR/bin" ] && [ -w "$PREFIX_DIR/bin" ]; then
        printf "%s\n" "$PREFIX_DIR/bin"
        return 0
    fi

    if [ -n "$HOME_DIR" ] && [ -d "$HOME_DIR/.local/bin" ] || [ -n "$HOME_DIR" ] && mkdir -p "$HOME_DIR/.local/bin" 2>/dev/null; then
        printf "%s\n" "$HOME_DIR/.local/bin"
        return 0
    fi

    if [ -n "$HOME_DIR" ] && [ -d "$HOME_DIR/bin" ] || [ -n "$HOME_DIR" ] && mkdir -p "$HOME_DIR/bin" 2>/dev/null; then
        printf "%s\n" "$HOME_DIR/bin"
        return 0
    fi

    if [ -d "/usr/local/bin" ] && [ -w "/usr/local/bin" ]; then
        printf "%s\n" "/usr/local/bin"
        return 0
    fi

    INSTALL_WARNING="no writable install directory was found; using the current directory only"
    pwd
}

choose_rc_file() {
    shell_name="$(current_shell_name)"

    case "$shell_name" in
        bash)
            if [ -n "$HOME_DIR" ]; then
                printf "%s\n" "$HOME_DIR/.bashrc"
                return 0
            fi
            ;;
        zsh)
            if [ -n "$HOME_DIR" ]; then
                printf "%s\n" "$HOME_DIR/.zshrc"
                return 0
            fi
            ;;
    esac

    if [ -n "$HOME_DIR" ]; then
        printf "%s\n" "$HOME_DIR/.profile"
        return 0
    fi

    printf "%s\n" ".profile"
}

remove_path_snippet_from_file() {
    rc_file="$1"
    [ -f "$rc_file" ] || return 0

    tmp_file="$rc_file.myip.tmp.$$"
    awk -v begin="$MARKER_BEGIN" -v end="$MARKER_END" '
        $0 == begin { skip=1; next }
        $0 == end { skip=0; next }
        skip != 1 { print }
    ' "$rc_file" > "$tmp_file" && mv "$tmp_file" "$rc_file"
}

remove_path_snippets() {
    if [ -n "$HOME_DIR" ]; then
        remove_path_snippet_from_file "$HOME_DIR/.bashrc"
        remove_path_snippet_from_file "$HOME_DIR/.zshrc"
        remove_path_snippet_from_file "$HOME_DIR/.profile"
    fi
}

path_contains_dir() {
    target="$1"
    old_ifs="${IFS}"
    IFS=":"
    for entry in $PATH; do
        if [ "$entry" = "$target" ]; then
            IFS="$old_ifs"
            return 0
        fi
    done
    IFS="$old_ifs"
    return 1
}

ensure_path_snippet() {
    dir="$1"
    rc_file="$(choose_rc_file)"

    if [ ! -f "$rc_file" ]; then
        if ! : > "$rc_file" 2>/dev/null; then
            PATH_UPDATE_FAILED="1"
            warn "cannot create $rc_file; add $dir to PATH manually"
            return 1
        fi
    fi

    if [ ! -w "$rc_file" ]; then
        PATH_UPDATE_FAILED="1"
        warn "cannot write to $rc_file; add $dir to PATH manually"
        return 1
    fi

    if grep -F "$MARKER_BEGIN" "$rc_file" >/dev/null 2>&1; then
        return 0
    fi

    {
        printf "\n%s\n" "$MARKER_BEGIN"
        printf "case \":\$PATH:\" in\n"
        printf "  *:%s:*) ;;\n" "$dir"
        printf "  *) export PATH=\"%s:\$PATH\" ;;\n" "$dir"
        printf "esac\n"
        printf "%s\n" "$MARKER_END"
    } >> "$rc_file"

    PATH_UPDATED="1"
}

self_install() {
    script_path="$1"

    if [ "$script_path" = "-" ] || [ "$script_path" = "sh" ] || [ "$script_path" = "/bin/sh" ] || [ ! -f "$script_path" ] 2>/dev/null; then
        RAN_FROM_STDIN="1"
        warn "cannot self-install when started from stdin or an ephemeral shell; save the script to a file and run it again"
        return 0
    fi

    case "$script_path" in
        /*) abs_path="$script_path" ;;
        *) abs_path="$(cd "$(dirname "$script_path")" && pwd)/$(basename "$script_path")" ;;
    esac

    install_dir="$(choose_install_dir)"
    target="$install_dir/$APP_NAME"
    INSTALL_TARGET="$target"
    INSTALL_NAME="$(basename "$target")"

    if [ "$abs_path" != "$target" ]; then
        existing_version=""
        if [ -f "$target" ]; then
            existing_version="$(extract_version "$target" || true)"
        fi

        if [ -n "$existing_version" ]; then
            comparison="$(version_compare "$VERSION" "$existing_version")"
            if [ "$comparison" = "-1" ]; then
                INSTALL_ACTION="blocked_newer"
                warn "installed copy at $target is newer ($existing_version); refusing to overwrite it with $VERSION"
            elif [ "$comparison" = "0" ]; then
                INSTALL_ACTION="reused"
            else
                tmp_target="$target.tmp.$$"
                cp "$abs_path" "$tmp_target"
                chmod 755 "$tmp_target"
                mv "$tmp_target" "$target"
                PREVIOUS_VERSION="$existing_version"
                INSTALL_ACTION="updated"
                INSTALL_CHANGED="1"
            fi
        else
            tmp_target="$target.tmp.$$"
            cp "$abs_path" "$tmp_target"
            chmod 755 "$tmp_target"
            mv "$tmp_target" "$target"
            INSTALL_ACTION="installed"
            INSTALL_CHANGED="1"
        fi
    else
        INSTALL_ACTION="reused"
    fi

    if ! path_contains_dir "$install_dir"; then
        ensure_path_snippet "$install_dir" || true
        PATH="$install_dir:$PATH"
        export PATH
    fi

    if [ -n "$INSTALL_WARNING" ]; then
        warn "$INSTALL_WARNING"
    fi

    if [ "$INSTALL_CHANGED" = "1" ] || [ "$PATH_UPDATED" = "1" ]; then
        if [ -z "$INSTALL_ACTION" ]; then
            INSTALL_ACTION="installed"
        fi
        print_install_result
    fi
}

print_usage() {
    cat <<'EOF'
Usage: myip [--json] [--ip] [--version] [--remove] [--update]

  --json     print raw JSON from ipapi.co
  --ip       print only the public IP
  --version  print version and install information
  --remove   remove installed myip, config, and PATH hook
  --update   update installed myip from GitHub
EOF
}

print_install_result() {
    case "$INSTALL_ACTION" in
        installed)
            info "$(green "$DISPLAY_NAME") версии $(green "$VERSION") установлен в $(green "$INSTALL_TARGET")"
            info "Команда: $(green "$APP_NAME")"
            ;;
        updated)
            info "$(green "$APP_NAME") successfully updated from $(green "$PREVIOUS_VERSION") to $(green "$VERSION")"
            info "Путь: $(green "$INSTALL_TARGET")"
            info "Команда: $(green "$APP_NAME")"
            ;;
        reused)
            info "$(green "$DISPLAY_NAME") версии $(green "$VERSION") уже установлен в $(green "$INSTALL_TARGET")"
            info "Команда: $(green "$APP_NAME")"
            ;;
        blocked_newer)
            info "$(green "$DISPLAY_NAME") версии $(green "$VERSION") не установлен поверх более новой копии в $(green "$INSTALL_TARGET")"
            ;;
    esac
}

print_version_info() {
    script_path="${INSTALL_TARGET:-}"
    if [ -z "$script_path" ]; then
        if command -v "$APP_NAME" >/dev/null 2>&1; then
            script_path="$(command -v "$APP_NAME")"
        else
            script_path="$0"
        fi
    fi

    info "$(green "$DISPLAY_NAME") версии $(green "$VERSION") установлен в $(green "$script_path")"
}

update_from_remote() {
    resolve_downloader

    if ! has_update_source; then
        warn "GitHub repository is not configured; set MYIP_GITHUB_REPO=owner/repo first"
        exit 1
    fi

    load_remote_version || {
        warn "failed to fetch update metadata from GitHub"
        exit 1
    }

    comparison="$(version_compare "$REMOTE_VERSION" "$VERSION")"
    if [ "$comparison" = "-1" ]; then
        warn "remote version $REMOTE_VERSION is older than local version $VERSION"
        exit 1
    fi
    if [ "$comparison" = "0" ]; then
        info "$(green "$APP_NAME") is already up to date at $(green "$VERSION")"
        return 0
    fi

    target_path=""
    if command -v "$APP_NAME" >/dev/null 2>&1; then
        target_path="$(command -v "$APP_NAME")"
    elif [ -f "$0" ]; then
        case "$0" in
            /*) target_path="$0" ;;
            *) target_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")" ;;
        esac
    fi

    if [ -z "$target_path" ]; then
        warn "could not determine installed target path for update"
        exit 1
    fi

    tmp_target="$target_path.tmp.$$"
    printf "%s\n" "$REMOTE_SCRIPT" > "$tmp_target"
    chmod 755 "$tmp_target"
    mv "$tmp_target" "$target_path"

    info "$(green "$APP_NAME") successfully updated from $(green "$VERSION") to $(green "$REMOTE_VERSION")"
    info "Путь: $(green "$target_path")"
}

remove_installation() {
    target_path=""

    if command -v "$APP_NAME" >/dev/null 2>&1; then
        target_path="$(command -v "$APP_NAME")"
    elif [ "$(basename "$0")" = "$APP_NAME" ] && [ -f "$0" ]; then
        case "$0" in
            /*) target_path="$0" ;;
            *) target_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")" ;;
        esac
    fi

    if [ -n "$target_path" ] && [ -f "$target_path" ]; then
        rm -f "$target_path"
        info "$(green "$APP_NAME") removed from $(green "$target_path")"
    else
        warn "installed binary was not found"
    fi

    remove_path_snippets

    if [ -f "$CONFIG_FILE" ]; then
        rm -f "$CONFIG_FILE"
    fi
    if [ -d "$CONFIG_DIR" ]; then
        rmdir "$CONFIG_DIR" 2>/dev/null || true
    fi

    info "PATH hook removed from shell rc files where present"
    info "Config removed from $(green "$CONFIG_DIR")"
}

print_json() {
    ensure_backend

    case "$ACTIVE_BACKEND" in
        ipapi)
            printf "%s\n" "$IPAPI_JSON"
            ;;
        2ip)
            ip="$(get_2ip_field "ip")"
            country="$(get_2ip_field "country_name")"
            region="$(get_2ip_field "region")"
            city="$(get_2ip_field "city")"
            org="$(get_2ip_field "org")"
            asn="$(get_2ip_field "asn")"
            timezone="$(get_2ip_field "timezone")"
            printf '{'
            printf '"backend":"2ip.me",'
            printf '"ip":"%s",' "$ip"
            printf '"country_name":"%s",' "$country"
            printf '"region":"%s",' "$region"
            printf '"city":"%s",' "$city"
            printf '"org":"%s",' "$org"
            printf '"asn":"%s",' "$asn"
            printf '"timezone":"%s"' "$timezone"
            printf '}\n'
            ;;
    esac
}

print_ip_only() {
    ensure_backend
    get_field "ip"
    printf "\n"
}

print_report() {
    ensure_backend
    ip="$(get_field "ip")"
    country="$(get_field "country_name")"
    region="$(get_field "region")"
    city="$(get_field "city")"
    org="$(get_field "org")"
    asn="$(get_field "asn")"
    timezone="$(get_field "timezone")"

    printf "IP: %s\n" "$(green "$ip")"
    printf "Country: %s\n" "$(green "$country")"
    printf "Region: %s\n" "$region"
    printf "City: %s\n" "$city"
    printf "Org: %s\n" "$org"
    printf "ASN: %s\n" "$asn"
    printf "Timezone: %s\n" "$timezone"
}

main() {
    load_config

    case "${1:-}" in
        --remove)
            remove_installation
            ;;
        "")
            resolve_downloader
            self_install "$0"
            print_report
            maybe_show_update_notice
            ;;
        --json)
            resolve_downloader
            self_install "$0"
            print_json
            maybe_show_update_notice
            ;;
        --ip)
            resolve_downloader
            self_install "$0"
            print_ip_only
            maybe_show_update_notice
            ;;
        --version)
            print_version_info
            resolve_downloader
            maybe_show_update_notice
            ;;
        --update)
            update_from_remote
            ;;
        -h|--help)
            print_usage
            ;;
        *)
            resolve_downloader
            self_install "$0"
            echo "myip: unknown option: $1" >&2
            print_usage >&2
            exit 1
            ;;
    esac
}

main "$@"
